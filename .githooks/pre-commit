#!/bin/bash
set -euo pipefail

files=()

while IFS= read -r -d "" file; do
  case "$file" in
    "Go CyclingTests/"*.swift | "Go CyclingUITests/"*.swift)
      files+=("$file")
      ;;
  esac
done < <(git diff --cached --name-only --diff-filter=ACMR -z)

if ((${#files[@]} == 0)); then
  exit 0
fi

xcrun swift-format lint --strict "${files[@]}"
